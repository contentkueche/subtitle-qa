{
  "manifestVersion": 5,
  "id": "com.subtitleqa.panel",
  "name": "Subtitle QA",
  "version": "0.1.39",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.6.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "subtitleQAPanel",
      "label": {
        "default": "Subtitle QA"
      },
      "minimumSize": {
        "width": 360,
        "height": 420
      },
      "preferredDockedSize": {
        "width": 420,
        "height": 720
      },
      "preferredFloatingSize": {
        "width": 620,
        "height": 760
      },
      "icon": {
        "width": 24,
        "height": 24,
        "path": "icons/subtitle-qa.svg",
        "theme": [
          "all"
        ],
        "species": [
          "generic",
          "pluginList"
        ]
      }
    }
  ],
  "icons": [
    {
      "width": 24,
      "height": 24,
      "path": "icons/subtitle-qa.svg",
      "theme": [
        "all"
      ],
      "species": [
        "generic",
        "pluginList"
      ]
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "enableAlerts": true,
    "network": {
      "domains": [
        "https://api.openai.com"
      ]
    }
  }
}
